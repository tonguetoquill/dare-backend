// colors.typ — Official Carnegie Mellon University palette.
// Source: CMU Brand Standards, brand.cmu.edu/visual-identity/colors.
//
// Rules encoded here (see components.typ for enforcement):
// - Core colors are the foundation and must dominate every layout.
// - Carnegie Red is the star; use it decisively, not everywhere.
// - Tartan/campus colors are accents only (thin rules, small highlights).

// ── Core palette ────────────────────────────────────────────────────────────
#let carnegie-red = rgb("#C41230") // PMS 187C  · CMYK 0/100/79/20
#let cmu-black = rgb("#000000") // PMS Black C
#let iron-gray = rgb("#6D6E71") // PMS Cool Gray 10 C · CMYK 0/0/0/70
#let steel-gray = rgb("#E0E0E0") // PMS Cool Gray 4 C  · CMYK 0/0/0/30
#let cmu-white = rgb("#FFFFFF")

// ── Secondary: tartan threads (internal-community accents) ─────────────────
#let scots-rose = rgb("#EF3A47") // PMS Red 032 C · CMYK 0/90/60/0
#let gold-thread = rgb("#FDB515") // PMS 130 C     · CMYK 0/32/100/0
#let green-thread = rgb("#009647") // PMS 348 C     · CMYK 93/0/98/17
#let teal-thread = rgb("#008F91") // PMS 7713 C    · CMYK 100/0/29/24
#let blue-thread = rgb("#043673") // PMS 288 C     · CMYK 100/75/6/24
#let highlands-sky = rgb("#007BC0") // PMS 640 C     · CMYK 100/11/3/12

// ── Secondary: campus palette ───────────────────────────────────────────────
#let skibo-red = rgb("#941120") // PMS 7623 C · CMYK 0/96/77/42
#let weaver-blue = rgb("#182C4B") // PMS 7463 C
#let hornbostel-teal = rgb("#1F4C4C") // PMS 7476 C
#let palladian-green = rgb("#719F94") // PMS 624 C
#let machinery-tan = rgb("#BCB49E") // PMS 7535 C
