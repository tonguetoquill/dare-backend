# ============================================
# DARE Backend Environment Variables
# ============================================
# Copy this file to .env and fill in your values.
#
# For Docker: docker-compose.yml overrides DB_HOST, REDIS_HOST,
# WEAVIATE_HOST, and OLLAMA_HOST to use container names.
# You only need to set API keys and credentials here.
# ============================================

# Django Settings
DJANGO_SETTINGS_MODULE='config.settings.local'
DJANGO_SECRET_KEY=
DJANGO_DEBUG='True'
ENVIRONMENT='local'
SITE_ID=1
ALLOWED_HOSTS=localhost,127.0.0.1

# Docker Compose runtime overrides
WEB_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
WEAVIATE_PORT=8080
WEAVIATE_GRPC_PORT=50051
WEAVIATE_CONSOLE_PORT=8081
OLLAMA_PORT=11434
DOCKER_DJANGO_SETTINGS_MODULE=config.settings.production
DOCKER_DJANGO_DEBUG=False
DOCKER_ENVIRONMENT=production
DOCKER_DB_HOST=postgres
DOCKER_REDIS_HOST=redis
DOCKER_WEAVIATE_HOST=weaviate
DOCKER_OLLAMA_HOST=http://ollama:11434

# CORS Settings - Update for your frontend URLs
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Database (Docker overrides DB_HOST to 'postgres')
DB_NAME=dare_dev
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432

# Email
EMAIL_BACKEND='django.core.mail.backends.console.EmailBackend'
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_FROM=

FRONTEND_CONFIRM_EMAIL_URL=http://localhost:5173/users/confirm-email/

# API Keys
PINECONE_API_KEY=pcsk_your_pinecone_api_key_here
PINECONE_INDEX_NAME=your_pinecone_index_name
OPENAI_API_KEY=sk-proj-your_openai_api_key_here
CLAUDE_API_KEY=sk-ant-your_anthropic_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
OLLAMA_HOST=http://localhost:11434

# Redis (Docker overrides REDIS_HOST to 'redis')
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

SENTRY_DSN=

# Weaviate (Docker overrides WEAVIATE_HOST to 'weaviate')
WEAVIATE_HOST=localhost
WEAVIATE_PORT=8080
WEAVIATE_COLLECTION_NAME=Document
WEAVIATE_SKIP_INIT_CHECKS=True

# Cross-Platform URLs (Required for unified access code system)
DARE_FRONTEND_URL=http://localhost:5173
SOCRATIC_BOTS_FRONTEND_URL=http://localhost:5173
DARE_BACKEND_URL=http://127.0.0.1:8000
SOCRATIC_BOTS_BACKEND_URL=http://127.0.0.1:8001

# Inter-service communication key
DARE_INTERNAL_KEY=local-dev-internal-key

MCP_USE_DOCKER=True

SYFTBOX_ENABLED="True"
SYFTBOX_DATASITES_ROOT=''
SYFTBOX_APP_NAME='dare'
SYFTBOX_BASE_URL='https://syftbox.net'
